<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="icon" href="../favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.bunny.net">
<link rel="stylesheet" href="https://fonts.bunny.net/css?family=inter:400,500,600,700,800|jetbrains-mono:400&display=swap">
<link rel="stylesheet" href="docs.css">
<script>
// Apply stored theme before first paint to prevent flash.
(function() {
  var t = localStorage.getItem("borescope-theme");
  if (t && t !== "auto") document.documentElement.setAttribute("data-theme", t);
})();
</script>
</head>
<body>

<a href="#main" class="skip-link">Skip to content</a>

<nav class="doc-nav" aria-label="Main">
  <div class="doc-nav-inner">
    <a href="../index.html" class="doc-nav-logo">
      <img src="../logo.svg" alt="borescope" width="28" height="28">
      <span>borescope</span>
    </a>
    <button class="doc-nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>
    <div class="doc-nav-links" id="nav-menu">
      <a href="index.html" class="current">Docs</a>
      <a href="../index.html#features">Features</a>
      <a href="https://github.com/tonyandrewmeyer/borescope" target="_blank" rel="noopener">GitHub</a>
      <button type="button" class="palette-trigger" aria-label="Search docs" aria-keyshortcuts="Control+K Meta+K">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
        <span>Search</span>
        <kbd>⌘K</kbd>
      </button>
      <div class="theme-switcher" role="group" aria-label="Colour theme">
        <button type="button" data-theme="light" aria-pressed="false">Light</button>
        <button type="button" data-theme="auto" aria-pressed="true">Auto</button>
        <button type="button" data-theme="dark" aria-pressed="false">Dark</button>
      </div>
    </div>
  </div>
</nav>

<dialog class="palette" aria-label="Search documentation">
  <div class="palette-inner">
    <div class="palette-input-row">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
      <input type="search" class="palette-input" placeholder="Search docs..." autocomplete="off" spellcheck="false" aria-label="Type to filter pages" aria-controls="palette-list" aria-activedescendant="">
      <kbd>Esc</kbd>
    </div>
    <ul class="palette-list" id="palette-list" role="listbox"></ul>
    <div class="palette-empty" hidden>No pages match. Try a different search.</div>
    <div class="palette-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
      <span><kbd>Enter</kbd> Open</span>
      <span><kbd>Esc</kbd> Close</span>
    </div>
  </div>
</dialog>

<script type="application/json" id="palette-data">{{ all_pages_json }}</script>

{%- if layout == "index" %}
<div class="doc-layout" style="max-width: var(--max-w); padding-top: 6rem;">
  <main id="main" class="doc-content">
    <h1>{{ h1 }}</h1>
    <p class="subtitle">
      {{ subtitle }}
    </p>

{{ body }}
  </main>
</div>
{%- else %}
<div class="doc-layout">
  <aside class="doc-sidebar">
    <h4>{{ sidebar_heading }}</h4>
    <ul>
{%- if primary_list == "on_this_page" %}
{%- for entry in on_this_page %}
{%- if loop.first %}
      <li><a href="#{{ entry.anchor }}" class="current">{{ entry.label }}</a></li>
{%- else %}
      <li><a href="#{{ entry.anchor }}">{{ entry.label }}</a></li>
{%- endif %}
{%- endfor %}
{%- else %}
{%- for page in section_pages %}
{%- if page.slug == slug %}
      <li><a href="{{ page.slug }}.html" class="current">{{ page.label }}</a></li>
{%- else %}
      <li><a href="{{ page.slug }}.html">{{ page.label }}</a></li>
{%- endif %}
{%- endfor %}
{%- endif %}
    </ul>
{%- if primary_list != "on_this_page" and on_this_page %}
    <h4>On this page</h4>
    <ul>
{%- for entry in on_this_page %}
      <li><a href="#{{ entry.anchor }}">{{ entry.label }}</a></li>
{%- endfor %}
    </ul>
{%- endif %}
{%- if see_also %}
    <h4>See also</h4>
    <ul>
{%- for entry in see_also %}
{%- if entry.external %}
      <li>
        <a href="{{ entry.href }}" target="_blank" rel="noopener">{{ entry.label }}</a>
      </li>
{%- else %}
      <li><a href="{{ entry.href }}">{{ entry.label }}</a></li>
{%- endif %}
{%- endfor %}
    </ul>
{%- endif %}
  </aside>

  <main id="main" class="doc-content">
    <div class="breadcrumb">
{%- if breadcrumb_label %}
      <a href="index.html">Docs</a><span class="sep">/</span>{{ section_label }}<span class="sep">/</span>{{ breadcrumb_label }}
{%- else %}
      <a href="index.html">Docs</a><span class="sep">/</span>{{ section_label }}
{%- endif %}
    </div>

    <h1>{{ h1 }}</h1>
    <p class="subtitle">
      {{ subtitle }}
    </p>

{{ body }}
  </main>
</div>
{%- endif %}

<footer class="doc-footer">
  <div class="doc-footer-inner">
    <span>borescope &middot; free &amp; open source &middot; Apache 2.0</span>
    <div>
      <a href="https://github.com/tonyandrewmeyer/borescope" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</footer>

<script>
(function() {
  var toggle = document.querySelector('.doc-nav-toggle');
  var links = document.querySelector('.doc-nav-links');
  if (!toggle || !links) return;
  toggle.addEventListener('click', function() {
    var open = links.classList.toggle('open');
    toggle.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
  links.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      links.classList.remove('open');
      toggle.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
    });
  });
})();

(function() {
  var root = document.documentElement;
  var buttons = document.querySelectorAll('.theme-switcher button');
  if (!buttons.length) return;
  var stored = localStorage.getItem('borescope-theme') || 'auto';
  function apply(theme) {
    if (theme === 'auto') root.removeAttribute('data-theme');
    else root.setAttribute('data-theme', theme);
    buttons.forEach(function(btn) {
      btn.setAttribute('aria-pressed', btn.getAttribute('data-theme') === theme ? 'true' : 'false');
    });
    localStorage.setItem('borescope-theme', theme);
  }
  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() { apply(btn.getAttribute('data-theme')); });
  });
  apply(stored);
})();

// Command palette: Cmd/Ctrl-K opens, type to filter, arrows to navigate.
(function() {
  var dialog = document.querySelector('.palette');
  var dataEl = document.getElementById('palette-data');
  var triggers = document.querySelectorAll('.palette-trigger');
  if (!dialog || !dataEl || typeof dialog.showModal !== 'function') return;

  var pages;
  try { pages = JSON.parse(dataEl.textContent); } catch (e) { return; }

  var input = dialog.querySelector('.palette-input');
  var list = dialog.querySelector('.palette-list');
  var empty = dialog.querySelector('.palette-empty');
  var here = (location.pathname.split('/').pop() || 'index.html').replace('.html', '');
  var idx = 0;
  var visible = [];

  function render(query) {
    var q = (query || '').toLowerCase().trim();
    list.innerHTML = '';
    visible = pages.filter(function(p) {
      if (!q) return true;
      return p.label.toLowerCase().indexOf(q) !== -1
          || p.section.toLowerCase().indexOf(q) !== -1
          || p.slug.toLowerCase().indexOf(q) !== -1;
    });
    if (!visible.length) {
      empty.hidden = false;
      input.setAttribute('aria-activedescendant', '');
      return;
    }
    empty.hidden = true;
    idx = 0;
    visible.forEach(function(p, i) {
      var li = document.createElement('li');
      li.id = 'palette-item-' + i;
      li.className = 'palette-item' + (p.slug === here ? ' current' : '');
      li.setAttribute('role', 'option');
      li.setAttribute('data-href', p.slug + '.html');
      li.innerHTML = '<span class="palette-item-label">' + p.label + '</span>'
                   + (p.section ? '<span class="palette-item-section">' + p.section + '</span>' : '<span class="palette-item-section">Index</span>');
      li.addEventListener('mouseenter', function() { setActive(i); });
      li.addEventListener('click', function() { open(visible[i]); });
      list.appendChild(li);
    });
    setActive(0);
  }

  function setActive(i) {
    if (!visible.length) return;
    idx = (i + visible.length) % visible.length;
    Array.prototype.forEach.call(list.children, function(li, j) {
      li.setAttribute('aria-selected', j === idx ? 'true' : 'false');
      if (j === idx) {
        input.setAttribute('aria-activedescendant', li.id);
        var top = li.offsetTop, bot = top + li.offsetHeight;
        if (top < list.scrollTop) list.scrollTop = top;
        else if (bot > list.scrollTop + list.clientHeight) list.scrollTop = bot - list.clientHeight;
      }
    });
  }

  function open(page) {
    if (!page) return;
    location.href = page.slug + '.html';
  }

  function show() {
    if (dialog.open) return;
    input.value = '';
    render('');
    dialog.showModal();
    setTimeout(function() { input.focus(); }, 0);
  }

  triggers.forEach(function(t) { t.addEventListener('click', show); });

  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) {
      e.preventDefault();
      if (dialog.open) dialog.close(); else show();
      return;
    }
    var typingInField = e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable);
    if (e.key === '/' && !typingInField && !dialog.open) {
      e.preventDefault();
      show();
    }
  });

  input.addEventListener('input', function() { render(input.value); });

  input.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(idx + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(idx - 1); }
    else if (e.key === 'Enter') { e.preventDefault(); open(visible[idx]); }
  });

  dialog.addEventListener('click', function(e) {
    var r = dialog.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
      dialog.close();
    }
  });
})();

(function() {
  document.querySelectorAll('.doc-content pre').forEach(function(pre) {
    var code = pre.querySelector('code');
    if (!code) return;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.addEventListener('click', function() {
      var text = code.innerText;
      var done = function() {
        btn.textContent = 'Copied';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 1500);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done, function() {});
      } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); done(); } catch (e) {}
        document.body.removeChild(ta);
      }
    });
    pre.appendChild(btn);
  });
})();
</script>

</body>
</html>
