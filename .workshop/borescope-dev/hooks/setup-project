#!/bin/bash -e
sudo -i -u workshop -- bash -e << 'EOF'
set -e
cd /project

# Install borescope and all pinned dev tools.
uv sync --group dev

# Install pre-commit hooks so linting runs automatically on every commit.
uv run pre-commit install

# If a built pebble binary was mounted via the `pebble` plug (a real executable,
# not the empty directory of an unconnected plug), put it on PATH.
src=/home/workshop/.local/bin/pebble-src
if [ -f "$src" ] && [ -x "$src" ]; then
    ln -sf "$src" /home/workshop/.local/bin/pebble
fi

# Pre-warm the unit and lint environments so the first run isn't slow.
uv run tox --notest -e unit,lint
EOF
