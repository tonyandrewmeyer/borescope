#!/bin/sh
# Juju plugin wrapper: `juju borescope <unit> ...` runs `juju-borescope <unit> ...`,
# which is just borescope. borescope already picks up the current controller/model
# like the juju CLI, so this is a thin passthrough. Put it on PATH (the snap
# does this automatically) to enable `juju borescope`.
exec "$(dirname "$(readlink -f "$0")")/borescope" "$@"
